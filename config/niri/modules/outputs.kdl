// https://yalter.github.io/niri/Configuration:-Outputs

output "eDP-1" {
  mode "1920x1080@60.001"
  scale 1.0

  hot-corners {
    // off
    // top-left
    // top-right
    // bottom-left
    bottom-right
  }
}

output "HDMI-A-1" {
  mode "1920x1080@75.000"
  position x=-1920 y=0
  focus-at-startup
  scale 1.0

  hot-corners {
    // off
    // top-left
    // top-right
    // bottom-left
    bottom-right
  }
}
